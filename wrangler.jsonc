{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "workerd-asynclocalstorage-bug-repro",
  "main": "src/index.js",
  "compatibility_date": "2026-03-01",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "EXAMPLE_DO",
        "class_name": "ExampleDO"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": [
        "ExampleDO"
      ]
    }
  ]
}